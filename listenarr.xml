<?xml version="1.0"?>
<Container version="2">
  <Name>listenarr</Name>
  <Repository>ghcr.io/listenarrs/listenarr:canary</Repository>
  <Registry>https://github.com/Listenarrs/Listenarr</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://forums.unraid.net/topic/122788-support-jpdvm2014-templates</Support>
  <Project>https://github.com/Listenarrs/Listenarr</Project>
  <Overview>Listenarr is a fast, feature-rich, cross-platform audiobook management server. Built with a focus on being a complete solution for all your audiobook downloading needs. Set up your own server and get ready to streamline your audiobook listening!</Overview>
  <Category>MediaApp:Other Status:Beta</Category>
  <WebUI>http://[IP]:[PORT:4545]</WebUI>
  <TemplateURL/>
  <Icon>https://cdn.jsdelivr.net/gh/selfhst/icons@main/png/listenarr.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>1768610210</DateInstalled>
  <DonateText>If you find this template useful, I’d love a coffee!</DonateText>
  <DonateLink>https://bmc.link/JPDVM2014</DonateLink>
  <Requires/>
  <Config Name="WebUI" Target="4545" Default="" Mode="tcp" Description="" Type="Port" Display="always" Required="true" Mask="false">4545</Config>
  <Config Name="Appdata" Target="/app/config" Default="/mnt/user/appdata/listenarr" Mode="rw" Description="" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/listenarr</Config>
  <Config Name="Audiobooks" Target="/audiobooks" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="Downloads" Target="/downloads" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="" Type="Variable" Display="advanced-hide" Required="true" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="" Type="Variable" Display="advanced-hide" Required="true" Mask="false">100</Config>
  <Config Name="UMASK" Target="UMASK" Default="022" Mode="" Description="" Type="Variable" Display="advanced-hide" Required="true" Mask="false">022</Config>
  <TailscaleStateDir/>
</Container>
